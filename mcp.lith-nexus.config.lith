(config
  (roots
    ["contracts" ".opencode/knowledge" ".opencode/promptdb" ".opencode/protocol" "specs" "manifest.lith"])
  (include_ext [".lith" ".lisp" ".md"])
  (ignore_glob ["**/node_modules/**" "**/dist/**" "**/.git/**"])
  (mime
    (lith "text/x-lith")
    (md "text/markdown"))
  (writes
    (facts_dir ".opencode/promptdb/facts")
    (inbox_dir ".opencode/knowledge/inbox"))
  (index
    (use_git_ls_files true)
    (watch false)))
